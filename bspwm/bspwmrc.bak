#! /bin/sh

pgrep -x sxhkd > /dev/null || sxhkd &
picom --config ~/.config/picom/picom.conf &
feh --bg-fill ~/Pictures/wallpaper/bspwm.png &
killall -q polybar
polybar -conf=~/.config/polybar/horizon.ini example &
dunst -conf ~/.config/dunst/dunstrc  &
clipmenud &

bspc monitor eDP-1 -d 1 2 3 4 5 6 7 8

bspc config normal_border_color "#282e3a"
bspc config focused_border_color "#6c6f93"
bspc config presel_feedback_color "#feb139"
bspc config border_width    2
bspc config window_gap      6
bspc config top_padding     30

bspc config split_ratio          0.52
bspc config borderless_monocle   false
bspc config gapless_monocle      false

bspc config focus_follows_pointer	true
bspc config pointer_follows_focus	false

#bspc rule -a Gimp desktop='^8' state=floating follow=on
#bspc rule -a Chromium desktop='^2'
bspc rule -a Klipper state=floating
bspc rule -a MEGAsync state=floating
#bspc rule -a Doom Emacs state=tile
#bspc rule -a Screenkey manage=off

xinput set-prop "ELAN1200:00 04F3:3087 Touchpad" "libinput Tapping Enabled" 1
xinput set-prop "ELAN1200:00 04F3:3087 Touchpad" "libinput Natural Scrolling Enabled" 1
wmname LG3D
export _JAVA_AWT_WM_NONREPARENTING=1
